    "version": "0.2.0",
    "configurations": [
        {
            "name": "mushaf_app (macOS debug)",
            "request": "launch",
            "type": "dart",
            "deviceId": "macos",
            "program": "lib/main.dart"
        },
        {
            "name": "mushaf_app (debug)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart"
        },
        {
            "name": "mushaf_app (profile)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "program": "lib/main.dart"
        },
        {
            "name": "mushaf_app (release)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "program": "lib/main.dart"
        },
        {
            "name": "Attach to Process",
            "request": "attach",
            "type": "dart",
            "vmServiceUri": "${command:dart.promptForVmService}"
        }
    ],
    "compounds": [
        {
            "name": "Debug macOS",
            "configurations": [
                "mushaf_app (macOS debug)"
            ]
